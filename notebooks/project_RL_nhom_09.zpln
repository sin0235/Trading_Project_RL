{"name":"project_RL_nhom_09","paragraphs":[{"title":"Overview","text":"%md\n# PPO Trading Showcase For Zeppelin\n\nDự án trình bày mô hình giao dịch cổ phiếu ứng dụng thuật toán PPO trong bài toán học tăng cường. Notebook này được xây dựng để tổng hợp kết quả huấn luyện, chỉ số đánh giá, so sánh với các chiến lược cơ sở và dữ liệu thị trường nhằm hỗ trợ theo dõi quá trình học của mô hình một cách trực quan.\n\n## Thành viên nhóm\nNhóm 9: \n- Trần Phúc Toàn\n- Phan Đình Sáng\n- Nguyễn Lâm Tấn\n","user":"sin235","dateUpdated":"2026-03-22T09:29:37+0000","progress":0,"config":{"lineNumbers":true,"tableHide":false,"editorSetting":{"language":"markdown","editOnDblClick":true,"completionKey":"TAB","completionSupport":false},"editorMode":"ace/mode/plain_text","colWidth":12,"editorHide":true,"fontSize":9,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<div class=\"markdown-body\">\n<h1>PPO Trading Showcase For Zeppelin</h1>\n<p>Dự án trình bày mô hình giao dịch cổ phiếu ứng dụng thuật toán PPO trong bài toán học tăng cường. Notebook này được xây dựng để tổng hợp kết quả huấn luyện, chỉ số đánh giá, so sánh với các chiến lược cơ sở và dữ liệu thị trường nhằm hỗ trợ theo dõi quá trình học của mô hình một cách trực quan.</p>\n<h2>Thành viên nhóm</h2>\n<p>Nhóm 9:</p>\n<ul>\n<li>Trần Phúc Toàn</li>\n<li>Phan Đình Sáng</li>\n<li>Nguyễn Lâm Tấn</li>\n</ul>\n\n</div>"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774171552366_3217557","id":"paragraph_4edfabf73fd04fe5bd1ec5fcb430c05d","dateCreated":"2026-03-22T09:25:52+0000","dateStarted":"2026-03-22T09:29:37+0000","dateFinished":"2026-03-22T09:29:37+0000","status":302,"focus":true},{"title":"Setup & Bind Data","text":"%spark.pyspark\nimport csv\nimport json\nimport sys\nfrom datetime import datetime\nfrom pathlib import Path\nfrom urllib import error as urlerror\nfrom urllib import request as urlrequest\n\nfrom pyspark.sql import functions as F\n\n\nDEFAULT_PROJECT_ROOT = \"/workspace/project\"\nDEFAULT_RESULTS_DIR = \"results/runs\"\nDEFAULT_DATA_DIR = \"data/processed\"\nDEFAULT_LIVE_TICKERS = \"FPT,VCB,HPG,VNM\"\nDEFAULT_BINDING = \"rlTradingShowcase\"\n\nspark.sparkContext.setLogLevel(\"WARN\")\n\n\ndef sfloat(value):\n    if value in (None, \"\"):\n        return None\n    try:\n        return float(value)\n    except (TypeError, ValueError):\n        return None\n\n\ndef sint(value):\n    if value in (None, \"\"):\n        return None\n    try:\n        return int(float(value))\n    except (TypeError, ValueError):\n        return None\n\n\ndef to_int(value, default):\n    try:\n        return int(str(value).strip())\n    except (TypeError, ValueError):\n        return default\n\n\ndef avg(values):\n    values = [value for value in values if value is not None]\n    return sum(values) / len(values) if values else None\n\n\ndef load_json(path):\n    if path is None or not path.exists():\n        return {}\n    with path.open(\"r\", encoding=\"utf-8\") as handle:\n        return json.load(handle)\n\n\ndef load_csv(path):\n    if path is None or not path.exists():\n        return []\n    with path.open(\"r\", encoding=\"utf-8\", newline=\"\") as handle:\n        return list(csv.DictReader(handle))\n\n\ndef normalize_text(value):\n    return str(value or \"\").strip().replace(\"\\\\\", \"/\")\n\n\ndef looks_like_windows_path(value):\n    value = normalize_text(value)\n    return len(value) > 1 and value[1] == \":\"\n\n\ndef candidate_path_texts(value, root=None):\n    raw = str(value or \"\").strip()\n    normalized = normalize_text(raw)\n    seen = set()\n    out = []\n\n    def add(candidate):\n        candidate = normalize_text(candidate)\n        if not candidate:\n            return\n        key = candidate.rstrip(\"/\")\n        if key not in seen:\n            seen.add(key)\n            out.append(candidate)\n\n    if raw:\n        if looks_like_windows_path(raw):\n            drive = normalized[0].lower()\n            tail = normalized[2:].lstrip(\"/\")\n            add(raw)\n            add(normalized)\n            add(\"/mnt/{0}/{1}\".format(drive, tail))\n            add(\"/\" + tail)\n        else:\n            add(raw)\n\n    if root is not None and raw and not looks_like_windows_path(raw) and not Path(normalized).is_absolute():\n        root_candidates = candidate_path_texts(root)\n        if not root_candidates:\n            root_candidates = [str(root)]\n        for base in root_candidates:\n            add(normalize_text(base).rstrip(\"/\") + \"/\" + normalized.lstrip(\"/\"))\n\n    return out\n\n\ndef candidate_paths(value, root=None):\n    seen = set()\n    out = []\n\n    def add(candidate):\n        if not candidate:\n            return\n        path = Path(str(candidate)).expanduser()\n        try:\n            path = path.resolve()\n        except OSError:\n            pass\n        key = str(path)\n        if key not in seen:\n            seen.add(key)\n            out.append(path)\n\n    for candidate in candidate_path_texts(value, root):\n        add(candidate)\n\n    return out\n\n\ndef search_roots():\n    cwd = Path.cwd().resolve()\n    roots = [cwd]\n    roots.extend(list(cwd.parents)[:4])\n    for extra in (\n        Path(\"/opt/zeppelin\"),\n        Path(\"/workspace\"),\n        Path(\"/mnt\"),\n        Path(\"/kaggle\"),\n        Path(\"/kaggle/working\"),\n        Path(\"/kaggle/working/repo\"),\n        Path(\"/kaggle/results\"),\n        Path(\"/content\"),\n        Path.home(),\n    ):\n        if extra.exists():\n            roots.append(extra.resolve())\n    uniq = []\n    seen = set()\n    for root in roots:\n        key = str(root)\n        if key not in seen:\n            seen.add(key)\n            uniq.append(root)\n    return uniq\n\n\ndef locate_dir(value, root=None, search_glob=False):\n    candidates = candidate_paths(value, root)\n    for candidate in candidates:\n        if candidate.exists():\n            return candidate.resolve()\n\n    normalized = normalize_text(value).strip(\"./\")\n    if normalized and not looks_like_windows_path(value) and not Path(normalized).is_absolute():\n        for base in search_roots():\n            direct = (base / normalized).resolve()\n            if direct.exists():\n                return direct\n        if search_glob:\n            pattern = \"**/\" + normalized\n            for base in search_roots():\n                try:\n                    for match in base.glob(pattern):\n                        if match.exists():\n                            return match.resolve()\n                except (OSError, RuntimeError):\n                    continue\n    return candidates[0] if candidates else None\n\n\ndef derive_root(project_root, runs_root, results_dir):\n    for candidate in candidate_paths(project_root):\n        if candidate.exists():\n            return candidate.resolve()\n    parts = [part for part in normalize_text(results_dir).strip(\"./\").split(\"/\") if part]\n    root = runs_root\n    for _ in parts:\n        root = root.parent\n    return root.resolve()\n\n\ndef first_match(run_dir, prefix, suffix):\n    direct = run_dir / (prefix + suffix)\n    if direct.exists():\n        return direct\n    matches = sorted(run_dir.glob(prefix + \"*\" + suffix))\n    return matches[0] if matches else None\n\n\ndef moving_avg(values, window):\n    if not values:\n        return []\n    out = []\n    running = 0.0\n    for index, value in enumerate(values):\n        running += value\n        if index >= window:\n            running -= values[index - window]\n        out.append(running / float(min(index + 1, window)))\n    return out\n\n\ndef svg_points(values, width=620, height=220, pad=14, low=None, high=None):\n    if not values:\n        return \"\", None, None, None\n    low = min(values) if low is None else low\n    high = max(values) if high is None else high\n    if low == high:\n        low -= 1.0\n        high += 1.0\n    xr = max(len(values) - 1, 1)\n    yr = high - low\n    pts = []\n    for index, value in enumerate(values):\n        x = pad + ((width - 2 * pad) * index / float(xr))\n        y = height - pad - (((value - low) / yr) * (height - 2 * pad))\n        pts.append(\"{0:.1f},{1:.1f}\".format(x, y))\n    zero_y = None\n    if low <= 0 <= high:\n        zero_y = height - pad - (((0 - low) / yr) * (height - 2 * pad))\n    return \" \".join(pts), round(low, 4), round(high, 4), (round(zero_y, 2) if zero_y is not None else None)\n\n\ndef stage(rows, label):\n    if not rows:\n        return {\"label\": label, \"avg_return_pct\": None, \"rows\": []}\n    return {\n        \"label\": label,\n        \"avg_return_pct\": round(avg([row[\"total_return_pct\"] for row in rows]) or 0.0, 4),\n        \"rows\": rows,\n    }\n\n\ndef parse_metrics(rows):\n    out = []\n    for row in rows:\n        out.append(\n            {\n                \"episode\": sint(row.get(\"episode\")) or 0,\n                \"portfolio_value\": sfloat(row.get(\"portfolio_value\")),\n                \"total_return_pct\": sfloat(row.get(\"total_return_pct\")),\n                \"n_trades\": sint(row.get(\"n_trades\")) or 0,\n            }\n        )\n    return sorted(out, key=lambda item: item[\"episode\"])\n\n\ndef parse_eval(rows):\n    out = []\n    for row in rows:\n        out.append(\n            {\n                \"episode\": sint(row.get(\"episode\")) or 0,\n                \"split\": row.get(\"split\"),\n                \"total_return\": sfloat(row.get(\"total_return\")),\n                \"sharpe_ratio\": sfloat(row.get(\"sharpe_ratio\")),\n            }\n        )\n    return sorted(out, key=lambda item: (item[\"episode\"], item[\"split\"] or \"\"))\n\n\ndef eval_payload(rows):\n    val_rows = [row for row in rows if row.get(\"split\") == \"val\"]\n    test_rows = [row for row in rows if row.get(\"split\") == \"test\"]\n    def pick(row):\n        return row or {}\n    return {\n        \"first_val\": pick(val_rows[0]) if val_rows else {},\n        \"last_val\": pick(val_rows[-1]) if val_rows else {},\n        \"final_test\": pick(test_rows[-1]) if test_rows else {},\n    }\n\n\ndef summary_payload(summary):\n    final_metrics = (summary or {}).get(\"final_metrics\", {})\n    return {\n        \"total_return\": sfloat(final_metrics.get(\"total_return\")),\n        \"sharpe_ratio\": sfloat(final_metrics.get(\"sharpe_ratio\")),\n        \"win_rate\": sfloat(final_metrics.get(\"win_rate\")),\n    }\n\n\ndef bench_payload(summary):\n    comparisons = ((summary or {}).get(\"extra\", {}) or {}).get(\"baseline_comparisons\", {})\n    stages = {}\n    for stage_name, baselines in comparisons.items():\n        current_stage = {}\n        for base_name, base_value in baselines.items():\n            metrics = base_value.get(\"baseline_metrics\", {}) if base_value else {}\n            current_stage[base_name] = {\n                \"label\": \"Danh mục đều\" if base_name == \"equal_weight\" else \"Mua và giữ\",\n                \"delta_total_return_pct\": round((sfloat(base_value.get(\"delta_total_return\")) or 0.0) * 100.0, 4),\n                \"delta_sharpe_ratio\": sfloat(base_value.get(\"delta_sharpe_ratio\")),\n                \"baseline_total_return_pct\": round((sfloat(metrics.get(\"total_return\")) or 0.0) * 100.0, 4),\n            }\n        stages[stage_name] = current_stage\n    rows = []\n    for stage_name, label in ((\"val\", \"Xác thực\"), (\"test\", \"Kiểm thử\")):\n        for base_name in (\"equal_weight\", \"buy_and_hold_equal_weight\"):\n            current = stages.get(stage_name, {}).get(base_name)\n            if current:\n                rows.append(\n                    {\n                        \"stage\": label,\n                        \"baseline\": current[\"label\"],\n                        \"delta_total_return_pct\": current[\"delta_total_return_pct\"],\n                        \"delta_sharpe_ratio\": current[\"delta_sharpe_ratio\"],\n                    }\n                )\n    return {\n        \"highlights\": {\n            \"test_equal_weight\": stages.get(\"test\", {}).get(\"equal_weight\", {}),\n            \"test_buy_hold\": stages.get(\"test\", {}).get(\"buy_and_hold_equal_weight\", {}),\n        },\n        \"rows\": rows,\n    }\n\n\ndef split_payload(summary):\n    split = ((summary or {}).get(\"extra\", {}) or {}).get(\"data_split\", {})\n    out = {}\n    for name in (\"train\", \"val\", \"test\"):\n        current = split.get(name, {})\n        out[name] = {\n            \"start\": current.get(\"start\"),\n            \"end\": current.get(\"end\"),\n            \"days\": current.get(\"days\"),\n        }\n    return out\n\n\ndef symbol_list(raw):\n    return [item.strip().upper() for item in str(raw or \"\").split(\",\") if item.strip()]\n\n\ndef last_csv_row(path):\n    if not path.exists():\n        return None\n    last = None\n    with path.open(\"r\", encoding=\"utf-8\", newline=\"\") as handle:\n        for row in csv.DictReader(handle):\n            last = row\n    return last\n\n\ndef live_quote(symbol, suffix):\n    quote_symbol = symbol if \".\" in symbol or \"^\" in symbol else symbol + suffix\n    url = \"https://query1.finance.yahoo.com/v8/finance/chart/{0}?interval=1d&range=5d\".format(quote_symbol)\n    request = urlrequest.Request(url, headers={\"User-Agent\": \"Mozilla/5.0\"})\n    with urlrequest.urlopen(request, timeout=8) as response:\n        payload = json.load(response)\n    result = (payload.get(\"chart\", {}).get(\"result\") or [None])[0]\n    if not result:\n        raise ValueError(\"No quote result\")\n    meta = result.get(\"meta\", {})\n    price = sfloat(meta.get(\"regularMarketPrice\"))\n    prev = sfloat(meta.get(\"chartPreviousClose\"))\n    change_pct = None if price is None or prev in (None, 0) else round(((price / prev) - 1.0) * 100.0, 4)\n    return {\n        \"quote_symbol\": quote_symbol,\n        \"live_price\": price,\n        \"change_pct\": change_pct,\n        \"market_time\": datetime.fromtimestamp(int(meta.get(\"regularMarketTime\"))).isoformat() if meta.get(\"regularMarketTime\") else None,\n    }\n\n\ndef build_live(data_dir, symbols, enable_live, suffix, limit):\n    available = sorted([path.stem.upper() for path in data_dir.glob(\"*.csv\")]) if data_dir.exists() else []\n    tracked = (symbols or available)[:limit]\n    rows = []\n    alerts = []\n    live_ready = False\n    for symbol in tracked:\n        last = last_csv_row(data_dir / (symbol + \".csv\")) if data_dir.exists() else None\n        row = {\n            \"symbol\": symbol,\n            \"last_date\": last.get(\"time\") if last else None,\n            \"last_close\": sfloat(last.get(\"close\")) if last else None,\n            \"live_price\": None,\n            \"change_pct\": None,\n            \"gap_vs_last_close_pct\": None,\n            \"status\": \"HISTORICAL_ONLY\",\n        }\n        if enable_live:\n            try:\n                quote = live_quote(symbol, suffix)\n                row.update(quote)\n                row[\"status\"] = \"LIVE\"\n                live_ready = True\n            except (urlerror.URLError, urlerror.HTTPError, ValueError, KeyError):\n                pass\n        if row[\"live_price\"] is not None and row[\"last_close\"] not in (None, 0):\n            row[\"gap_vs_last_close_pct\"] = round(((row[\"live_price\"] / row[\"last_close\"]) - 1.0) * 100.0, 4)\n            if abs(row[\"gap_vs_last_close_pct\"]) >= 2.0:\n                alerts.append(\"{0} lệch {1:+.2f}% so với giá đóng cửa đã xử lý\".format(symbol, row[\"gap_vs_last_close_pct\"]))\n        rows.append(row)\n    status = \"Đã lấy được giá trực tiếp\" if live_ready else (\"Đang chạy với dữ liệu cục bộ\" if not enable_live else \"Không lấy được giá trực tiếp\")\n    return {\n        \"rows\": rows,\n        \"alerts\": alerts,\n        \"status_label\": status,\n        \"tracked_symbols\": tracked,\n        \"refreshed_at\": datetime.now().astimezone().strftime(\"%Y-%m-%d %H:%M:%S %z\"),\n    }\n\n\ndef build_payload(project_root, results_dir, data_dir, preview_rows, live_tickers, enable_live, suffix, live_limit):\n    runs_root = locate_dir(results_dir, project_root, search_glob=True)\n    if runs_root is None or not runs_root.exists():\n        checked = [str(path) for path in candidate_paths(results_dir, project_root)[:4]]\n        raise FileNotFoundError(\n            \"Results directory not found. Try setting project_root to the path visible inside Zeppelin. Checked: {0}\".format(\n                checked\n            )\n        )\n    root = derive_root(project_root, runs_root, results_dir)\n    data_root = locate_dir(data_dir, root, search_glob=True)\n    if data_root is None:\n        data_root = (root / normalize_text(data_dir).strip(\"./\")).resolve()\n\n    runs = []\n    for run_dir in sorted([path for path in runs_root.iterdir() if path.is_dir()], key=lambda item: item.name):\n        metrics_path = first_match(run_dir, \"metrics\", \".csv\")\n        if metrics_path is None:\n            continue\n        metrics = parse_metrics(load_csv(metrics_path))\n        if not metrics:\n            continue\n        evals = parse_eval(load_csv(first_match(run_dir, \"eval_metrics\", \".csv\")))\n        config = load_json(first_match(run_dir, \"config\", \".json\"))\n        summary = load_json(first_match(run_dir, \"summary\", \".json\"))\n        train_steps = load_csv(first_match(run_dir, \"train_steps\", \".csv\"))\n        window = 1 if len(metrics) <= 4 else min(preview_rows, 10)\n        early = metrics[:window]\n        late = metrics[-window:]\n        returns = [row[\"total_return_pct\"] or 0.0 for row in metrics]\n        ma = moving_avg(returns, max(2, min(10, len(metrics))))\n        low = min(returns + ma) if returns else None\n        high = max(returns + ma) if returns else None\n        raw_points, low, high, zero_y = svg_points(returns, low=low, high=high)\n        ma_points, _, _, _ = svg_points(ma, low=low, high=high)\n        early_stage = stage(early, \"Giai đoạn đầu ({0} -> {1})\".format(early[0][\"episode\"], early[-1][\"episode\"]))\n        late_stage = stage(late, \"Giai đoạn cuối ({0} -> {1})\".format(late[0][\"episode\"], late[-1][\"episode\"]))\n        delta = None\n        if early_stage[\"avg_return_pct\"] is not None and late_stage[\"avg_return_pct\"] is not None:\n            delta = round(late_stage[\"avg_return_pct\"] - early_stage[\"avg_return_pct\"], 4)\n        best = max(metrics, key=lambda item: item[\"total_return_pct\"] if item[\"total_return_pct\"] is not None else float(\"-inf\"))\n        worst = min(metrics, key=lambda item: item[\"total_return_pct\"] if item[\"total_return_pct\"] is not None else float(\"inf\"))\n        bench = bench_payload(summary)\n        runs.append(\n            {\n                \"run_id\": run_dir.name,\n                \"label\": \"{0} ({1} tập)\".format(run_dir.name, len(metrics)),\n                \"total_episodes\": len(metrics),\n                \"total_updates\": len(train_steps),\n                \"early\": early_stage,\n                \"late\": late_stage,\n                \"delta_return_pct\": delta,\n                \"best_episode\": best,\n                \"worst_episode\": worst,\n                \"eval\": eval_payload(evals),\n                \"summary\": summary_payload(summary),\n                \"split\": split_payload(summary),\n                \"config\": {\n                    \"total_timesteps\": config.get(\"total_timesteps\"),\n                    \"n_steps\": config.get(\"n_steps\"),\n                    \"batch_size\": config.get(\"batch_size\"),\n                    \"hidden_size\": config.get(\"hidden_size\"),\n                    \"max_steps_train\": config.get(\"max_steps_train\"),\n                    \"max_steps_eval\": config.get(\"max_steps_eval\"),\n                },\n                \"chart\": {\n                    \"raw_points\": raw_points,\n                    \"ma_points\": ma_points,\n                    \"min_value\": low,\n                    \"max_value\": high,\n                    \"zero_y\": zero_y,\n                    \"latest_value\": round(returns[-1], 4) if returns else None,\n                },\n                \"benchmarks\": bench,\n                \"started_at\": summary.get(\"start_time\"),\n                \"ended_at\": summary.get(\"end_time\"),\n            }\n        )\n    if not runs:\n        raise ValueError(\"No usable runs found under: {0}\".format(runs_root))\n    default_run = max(runs, key=lambda item: item[\"total_episodes\"])\n    return {\n        \"project\": {\"project_root\": str(root), \"results_dir\": str(runs_root), \"data_dir\": str(data_root)},\n        \"defaultRunId\": default_run[\"run_id\"],\n        \"runs\": runs,\n        \"runMap\": {run[\"run_id\"]: run for run in runs},\n        \"liveMarket\": build_live(data_root, live_tickers, enable_live, suffix, live_limit),\n    }\n\n\nPROJECT_ROOT = z.input(\"project_root\", DEFAULT_PROJECT_ROOT)\nRESULTS_DIR = z.input(\"results_dir\", DEFAULT_RESULTS_DIR)\nDATA_DIR = z.input(\"data_dir\", DEFAULT_DATA_DIR)\nLIVE_TICKERS = z.input(\"live_tickers\", DEFAULT_LIVE_TICKERS)\nENABLE_LIVE_QUOTES = str(z.input(\"enable_live_quotes\", \"true\")).strip().lower() in (\"true\", \"1\", \"yes\", \"y\")\nMARKET_SUFFIX = z.input(\"market_suffix\", \".VN\").strip() or \".VN\"\nPREVIEW_ROWS = to_int(z.input(\"preview_rows\", \"8\"), 8)\nLIVE_LIMIT = to_int(z.input(\"live_limit\", \"4\"), 4)\nENABLE_CHECKPOINT_REPLAY = str(z.input(\"enable_checkpoint_replay\", \"true\")).strip().lower() in (\"true\", \"1\", \"yes\", \"y\")\nREPLAY_MONTHS = to_int(z.input(\"replay_months\", \"4\"), 4)\nREPLAY_WARMUP_MONTHS = to_int(z.input(\"replay_warmup_months\", \"4\"), 4)\nREPLAY_RUN_LIMIT = to_int(z.input(\"replay_run_limit\", \"3\"), 3)\nCHECKPOINT_SAMPLES = to_int(z.input(\"checkpoint_samples\", \"4\"), 4)\nVNSTOCK_SOURCE = z.input(\"vnstock_source\", \"VCI\").strip() or \"VCI\"\n\npayload = build_payload(\n    PROJECT_ROOT,\n    RESULTS_DIR,\n    DATA_DIR,\n    PREVIEW_ROWS,\n    symbol_list(LIVE_TICKERS),\n    ENABLE_LIVE_QUOTES,\n    MARKET_SUFFIX,\n    LIVE_LIMIT,\n)\npayload[\"checkpointReplay\"] = {\n    \"status\": \"disabled\",\n    \"message\": \"Đã tắt replay checkpoint trong form cấu hình.\",\n    \"warnings\": [],\n    \"runs\": [],\n    \"runMap\": {},\n    \"defaultRunId\": None,\n}\nif ENABLE_CHECKPOINT_REPLAY:\n    try:\n        resolved_project_root = str(Path(payload[\"project\"][\"project_root\"]).resolve())\n        if resolved_project_root not in sys.path:\n            sys.path.insert(0, resolved_project_root)\n        from scripts.zeppelin_checkpoint_replay_helpers import build_checkpoint_replay_payload\n        payload[\"checkpointReplay\"] = build_checkpoint_replay_payload(\n            project_root=resolved_project_root,\n            results_dir=payload[\"project\"][\"results_dir\"],\n            data_dir=payload[\"project\"][\"data_dir\"],\n            recent_months=max(REPLAY_MONTHS, 1),\n            warmup_months=max(REPLAY_WARMUP_MONTHS, 1),\n            run_limit=max(REPLAY_RUN_LIMIT, 1),\n            checkpoint_samples=max(CHECKPOINT_SAMPLES, 1),\n            vnstock_source=VNSTOCK_SOURCE,\n        )\n    except Exception as exc:\n        payload[\"checkpointReplay\"] = {\n            \"status\": \"error\",\n            \"message\": str(exc),\n            \"warnings\": [str(exc)],\n            \"runs\": [],\n            \"runMap\": {},\n            \"defaultRunId\": None,\n        }\nz.angularBind(DEFAULT_BINDING, payload)\n\noverview_rows = []\nfor run in payload[\"runs\"]:\n    eq = run[\"benchmarks\"][\"highlights\"].get(\"test_equal_weight\", {})\n    bh = run[\"benchmarks\"][\"highlights\"].get(\"test_buy_hold\", {})\n    overview_rows.append(\n        {\n            \"run_id\": run[\"run_id\"],\n            \"episodes\": run[\"total_episodes\"],\n            \"sharpe_ratio\": run[\"summary\"].get(\"sharpe_ratio\"),\n            \"test_total_return_pct\": round(((run[\"summary\"].get(\"total_return\") or 0.0) * 100.0), 4),\n            \"early_late_delta_pct\": run.get(\"delta_return_pct\"),\n            \"test_vs_equal_weight_pct\": eq.get(\"delta_total_return_pct\"),\n            \"test_vs_buy_hold_pct\": bh.get(\"delta_total_return_pct\"),\n        }\n    )\nspark.createDataFrame(overview_rows).createOrReplaceTempView(\"training_overview_demo\")\n\nprint(\n    json.dumps(\n        {\n            \"defaultRunId\": payload[\"defaultRunId\"],\n            \"liveStatus\": payload[\"liveMarket\"][\"status_label\"],\n            \"trackedSymbols\": payload[\"liveMarket\"][\"tracked_symbols\"],\n            \"tempView\": \"training_overview_demo\",\n            \"replayStatus\": payload[\"checkpointReplay\"][\"status\"],\n            \"replayRuns\": [run[\"run_id\"] for run in payload[\"checkpointReplay\"].get(\"runs\", [])],\n        },\n        indent=2,\n        ensure_ascii=False,\n    )\n)","user":"sin235","dateUpdated":"2026-03-22T09:29:37+0000","progress":0,"config":{"lineNumbers":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true},"editorMode":"ace/mode/plain_text","colWidth":12,"editorHide":false,"fontSize":9,"results":{},"enabled":true},"settings":{"params":{"project_root":"/workspace/project","results_dir":"results/runs","data_dir":"data/processed","live_tickers":"FPT,VCB,HPG,VNM","enable_live_quotes":"true","market_suffix":".VN","preview_rows":"8","live_limit":"4"},"forms":{"project_root":{"type":"TextBox","name":"project_root","displayName":"project_root","defaultValue":"/workspace/project","hidden":false},"results_dir":{"type":"TextBox","name":"results_dir","displayName":"results_dir","defaultValue":"results/runs","hidden":false},"data_dir":{"type":"TextBox","name":"data_dir","displayName":"data_dir","defaultValue":"data/processed","hidden":false},"live_tickers":{"type":"TextBox","name":"live_tickers","displayName":"live_tickers","defaultValue":"FPT,VCB,HPG,VNM","hidden":false},"enable_live_quotes":{"type":"TextBox","name":"enable_live_quotes","displayName":"enable_live_quotes","defaultValue":"true","hidden":false},"market_suffix":{"type":"TextBox","name":"market_suffix","displayName":"market_suffix","defaultValue":".VN","hidden":false},"preview_rows":{"type":"TextBox","name":"preview_rows","displayName":"preview_rows","defaultValue":"8","hidden":false},"live_limit":{"type":"TextBox","name":"live_limit","displayName":"live_limit","defaultValue":"4","hidden":false}}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"{\n  \"defaultRunId\": \"ppo_20260322_013613\",\n  \"liveStatus\": \"Live quote dang san sang\",\n  \"trackedSymbols\": [\n    \"FPT\",\n    \"VCB\",\n    \"HPG\",\n    \"VNM\"\n  ],\n  \"tempView\": \"training_overview_demo\"\n}\n"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774171552368_405052102","id":"paragraph_b9712ad03f754b54adc33fc4a4fd4e60","dateCreated":"2026-03-22T09:25:52+0000","dateStarted":"2026-03-22T09:29:37+0000","dateFinished":"2026-03-22T09:29:40+0000","status":302},{"title":"SQL Overview","text":"%spark.sql\r\nSELECT\r\n  run_id,\r\n  episodes,\r\n  ROUND(test_total_return_pct, 2) AS test_total_return_pct,\r\n  ROUND(sharpe_ratio, 3) AS sharpe_ratio,\r\n  ROUND(early_late_delta_pct, 2) AS early_late_delta_pct,\r\n  ROUND(test_vs_equal_weight_pct, 2) AS test_vs_equal_weight_pct,\r\n  ROUND(test_vs_buy_hold_pct, 2) AS test_vs_buy_hold_pct\r\nFROM training_overview_demo\r\nORDER BY test_total_return_pct DESC\r\n","user":"sin235","dateUpdated":"2026-03-22T09:29:40+0000","progress":0,"config":{"lineNumbers":true,"editorSetting":{"language":"sql","editOnDblClick":false,"completionKey":"TAB","completionSupport":true},"editorMode":"ace/mode/plain_text","colWidth":12,"editorHide":false,"fontSize":9,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TABLE","data":"run_id\tepisodes\ttest_total_return_pct\tsharpe_ratio\tearly_late_delta_pct\ttest_vs_equal_weight_pct\ttest_vs_buy_hold_pct\nppo_20260322_054037\t976\t51.48\t1.495\t9.47\t0.95\t-20.3\nppo_20260321_182452\t976\t51.42\t1.385\t13.69\t3.24\t-18.98\nppo_20260322_043224\t976\t49.48\t1.458\t14.1\t0.39\t-22.3\nppo_20260322_041700\t976\t48.19\t1.311\t12.73\t0.8\t-22.2\nppo_20260322_013613\t1953\t44.4\t1.349\t8.5\t0.1\t-15.43\nppo_20260321_163545\t781\t43.31\t1.161\t20.38\t-2.66\t-27.09\nppo_20260322_025738\t976\t42.73\t1.295\t16.41\t-1.58\t-17.11\nppo_20260321_180000\t781\t40.05\t1.154\t15.18\t-8.12\t-30.34\nppo_20260321_173239\t781\t39.95\t1.102\t19.48\t-6.05\t-30.44\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://d72734c2d160:4040/jobs/job?id=2"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774171552370_673054965","id":"paragraph_982a8c2ed5a34bcd9a21baf6386aa22b","dateCreated":"2026-03-22T09:25:52+0000","dateStarted":"2026-03-22T09:29:40+0000","dateFinished":"2026-03-22T09:29:41+0000","status":302},{"title":"Angular Dashboard","text":"%angular\n<style>\n  .rl-shell {\n    --ink: #142538;\n    --muted: #55667c;\n    --line: #d8e2ec;\n    --panel: rgba(255, 255, 255, 0.94);\n    --panel-strong: #0f2137;\n    --paper: #f7fbff;\n    --sea: #0f766e;\n    --sea-soft: #dff6f1;\n    --amber: #a16207;\n    --amber-soft: #fff3d8;\n    --rose: #b42318;\n    --rose-soft: #fde8e8;\n    --sky: #1d4ed8;\n    --sky-soft: #e6f0ff;\n    font-family: 'Aptos', 'Trebuchet MS', 'Segoe UI', sans-serif;\n    color: var(--ink);\n    background:\n      radial-gradient(circle at top right, rgba(255, 214, 153, 0.38), transparent 30%),\n      radial-gradient(circle at left bottom, rgba(166, 229, 202, 0.30), transparent 25%),\n      linear-gradient(180deg, #fffdf8 0%, #f5f9fc 100%);\n    border: 1px solid #eadfce;\n    border-radius: 28px;\n    padding: 24px;\n  }\n  .rl-hero,\n  .rl-replay-grid,\n  .rl-main,\n  .rl-bottom,\n  .rl-stage-grid,\n  .rl-card-grid,\n  .rl-detail-grid {\n    display: grid;\n    gap: 16px;\n  }\n  .rl-hero { grid-template-columns: 1.35fr 0.95fr; margin-bottom: 18px; }\n  .rl-replay-grid { grid-template-columns: 0.95fr 1.05fr; margin-bottom: 18px; }\n  .rl-main { grid-template-columns: 1.3fr 1fr; margin-bottom: 18px; }\n  .rl-bottom { grid-template-columns: 1fr 1fr; margin-bottom: 18px; }\n  .rl-stage-grid { grid-template-columns: 1fr 1fr; }\n  .rl-card-grid { grid-template-columns: repeat(6, minmax(0, 1fr)); margin-bottom: 18px; }\n  .rl-detail-grid { grid-template-columns: 1fr 1fr; }\n  .rl-panel {\n    background: var(--panel);\n    border: 1px solid rgba(216, 226, 236, 0.98);\n    border-radius: 20px;\n    padding: 18px;\n    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);\n  }\n  .rl-panel h2, .rl-panel h3, .rl-panel h4 {\n    margin: 0 0 10px 0;\n    color: var(--ink);\n  }\n  .rl-panel p {\n    margin: 0 0 12px 0;\n    color: var(--muted);\n    line-height: 1.6;\n  }\n  .rl-kicker {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    padding: 6px 10px;\n    border-radius: 999px;\n    background: #e4f6ec;\n    color: #15624f;\n    font-size: 12px;\n    font-weight: 800;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    margin-bottom: 10px;\n  }\n  .rl-chip-row, .rl-badge-row, .rl-alerts, .rl-meta-row { display: flex; flex-wrap: wrap; gap: 8px; }\n  .rl-chip, .rl-badge {\n    border-radius: 999px;\n    padding: 7px 11px;\n    font-size: 12px;\n    font-weight: 700;\n  }\n  .rl-chip { background: #edf5ff; color: #27496f; }\n  .rl-badge { background: var(--sea-soft); color: var(--sea); }\n  .rl-side {\n    background: linear-gradient(180deg, #12263d 0%, #0f172a 100%);\n    color: #f8fbff;\n  }\n  .rl-side h3, .rl-side p, .rl-side strong { color: #f8fbff; }\n  .rl-side label, .rl-control label {\n    display: block;\n    margin-bottom: 8px;\n    font-size: 12px;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    font-weight: 700;\n  }\n  .rl-side label { color: #d7e4f2; }\n  .rl-select, .rl-slider {\n    width: 100%;\n    box-sizing: border-box;\n  }\n  .rl-select {\n    padding: 11px 12px;\n    border-radius: 14px;\n    border: 1px solid rgba(20, 37, 56, 0.12);\n    background: #fffefb;\n    color: var(--ink);\n    box-shadow: inset 0 0 0 1px rgba(19, 34, 56, 0.03);\n    margin-bottom: 12px;\n  }\n  .rl-side .rl-select {\n    border-color: rgba(255, 255, 255, 0.18);\n    background: #fffefb;\n  }\n  .rl-side-grid { display: grid; gap: 12px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\n  .rl-mini {\n    background: rgba(255, 255, 255, 0.10);\n    border-radius: 16px;\n    padding: 12px;\n  }\n  .rl-mini span {\n    display: block;\n    color: #d7e4f2;\n    font-size: 12px;\n    margin-bottom: 4px;\n  }\n  .rl-mini strong { font-size: 21px; font-weight: 800; }\n  .rl-card {\n    background: rgba(255,255,255,0.95);\n    border: 1px solid rgba(216, 226, 236, 0.98);\n    border-radius: 18px;\n    padding: 16px;\n    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);\n  }\n  .rl-card-label {\n    color: #4a5d74;\n    font-size: 12px;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    margin-bottom: 8px;\n    font-weight: 700;\n  }\n  .rl-card-value {\n    font-size: 26px;\n    font-weight: 800;\n    line-height: 1.08;\n    color: var(--ink);\n  }\n  .rl-card-sub, .rl-note {\n    margin-top: 8px;\n    color: var(--muted);\n    font-size: 12px;\n    line-height: 1.5;\n  }\n  .rl-positive { color: #117a46; }\n  .rl-negative { color: var(--rose); }\n  .rl-chart-meta span, .rl-status {\n    border-radius: 999px;\n    padding: 6px 10px;\n    font-size: 12px;\n    font-weight: 700;\n  }\n  .rl-chart-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }\n  .rl-chart-meta span { background: #ecfdf7; color: #16645a; }\n  .rl-status { display: inline-flex; background: #eef5ff; color: #285e91; }\n  .rl-live { background: #e9fbee; color: #16643b; }\n  .rl-fallback { background: #fff3e6; color: #9a5d08; }\n  .rl-chart-box {\n    background: linear-gradient(180deg, #ffffff 0%, #eef6ff 100%);\n    border-radius: 18px;\n    padding: 10px;\n    border: 1px solid rgba(216, 226, 236, 0.8);\n  }\n  .rl-chart-box svg { width: 100%; height: 280px; }\n  .rl-replay-chart svg { width: 100%; height: 310px; }\n  .rl-replay-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    gap: 12px;\n    margin-bottom: 10px;\n  }\n  .rl-control-grid { display: grid; gap: 12px; grid-template-columns: 1fr 1fr; }\n  .rl-control {\n    background: #f6fbff;\n    border: 1px solid rgba(216, 226, 236, 0.9);\n    border-radius: 16px;\n    padding: 12px;\n  }\n  .rl-frame-box {\n    background: linear-gradient(180deg, #0f2137 0%, #17314f 100%);\n    color: #f8fbff;\n    border-radius: 18px;\n    padding: 16px;\n    margin-top: 14px;\n  }\n  .rl-frame-box h4, .rl-frame-box p, .rl-frame-box strong { color: #f8fbff; }\n  .rl-frame-box p { color: #d6e5f5; }\n  .rl-frame-metrics { display: grid; gap: 10px; grid-template-columns: repeat(3, minmax(0, 1fr)); margin-top: 12px; }\n  .rl-metric {\n    background: rgba(255,255,255,0.08);\n    border-radius: 14px;\n    padding: 12px;\n  }\n  .rl-metric span { display: block; color: #d6e5f5; font-size: 12px; margin-bottom: 4px; }\n  .rl-metric strong { font-size: 20px; }\n  .rl-slider {\n    margin: 12px 0 8px 0;\n    accent-color: var(--sea);\n  }\n  .rl-slider-row {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-top: 6px;\n  }\n  .rl-btn {\n    border: none;\n    border-radius: 999px;\n    padding: 8px 12px;\n    background: #e8f3ff;\n    color: #24486b;\n    font-weight: 700;\n    cursor: pointer;\n  }\n  .rl-btn[disabled] { opacity: 0.45; cursor: default; }\n  .rl-btn-primary { background: #dff6f1; color: var(--sea); }\n  .rl-table { width: 100%; border-collapse: collapse; }\n  .rl-table th, .rl-table td {\n    padding: 10px 8px;\n    border-bottom: 1px solid var(--line);\n    text-align: left;\n    font-size: 13px;\n    vertical-align: top;\n  }\n  .rl-table th { color: #4a5d74; font-weight: 700; }\n  .rl-table td { color: var(--ink); }\n  .rl-alert {\n    border-radius: 999px;\n    padding: 7px 11px;\n    background: var(--amber-soft);\n    color: var(--amber);\n    font-size: 12px;\n    font-weight: 700;\n  }\n  .rl-empty {\n    border: 1px dashed rgba(180, 35, 24, 0.35);\n    background: #fff6f6;\n  }\n  .rl-muted { color: var(--muted); }\n  .rl-terminal-panel {\n    background: linear-gradient(180deg, #0c1928 0%, #10263f 100%);\n    border-color: rgba(114, 148, 183, 0.25);\n    color: #f7fbff;\n  }\n  .rl-terminal-panel h3, .rl-terminal-panel h4, .rl-terminal-panel strong { color: #f7fbff; }\n  .rl-terminal-panel p, .rl-terminal-panel .rl-muted { color: #cfe0f0; }\n  .rl-terminal-panel .rl-chart-box {\n    background: linear-gradient(180deg, rgba(7, 15, 24, 0.95) 0%, rgba(16, 33, 55, 0.92) 100%);\n    border-color: rgba(114, 148, 183, 0.20);\n  }\n  .rl-terminal-panel .rl-chip { background: rgba(255,255,255,0.08); color: #eef6ff; }\n  .rl-ticker-tape { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0 2px 0; }\n  .rl-ticker-chip {\n    border-radius: 999px;\n    padding: 6px 10px;\n    background: rgba(255,255,255,0.08);\n    border: 1px solid rgba(255,255,255,0.10);\n    color: #eef6ff;\n    font-size: 12px;\n    font-weight: 700;\n  }\n  .rl-speed-row, .rl-legend { display: flex; flex-wrap: wrap; gap: 8px; }\n  .rl-speed-row { margin-top: 10px; }\n  .rl-legend { margin-top: 10px; }\n  .rl-legend span {\n    border-radius: 999px;\n    padding: 6px 10px;\n    font-size: 12px;\n    font-weight: 700;\n    background: rgba(255,255,255,0.08);\n    color: #eef6ff;\n  }\n  .rl-market-strip {\n    display: grid;\n    gap: 10px;\n    grid-template-columns: repeat(4, minmax(0, 1fr));\n    margin-top: 12px;\n  }\n  .rl-market-tile {\n    border-radius: 14px;\n    padding: 12px;\n    background: rgba(255,255,255,0.08);\n    border: 1px solid rgba(255,255,255,0.10);\n  }\n  .rl-market-tile span { display: block; color: #d6e5f5; font-size: 12px; margin-bottom: 4px; }\n  .rl-market-tile strong { font-size: 20px; }\n  .rl-progress-line {\n    height: 8px;\n    border-radius: 999px;\n    background: rgba(255,255,255,0.10);\n    overflow: hidden;\n    margin-top: 12px;\n  }\n  .rl-progress-line > div {\n    height: 100%;\n    border-radius: 999px;\n    background: linear-gradient(90deg, #0f766e 0%, #2dd4bf 100%);\n  }\n  @media (max-width: 1380px) { .rl-card-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }\n  @media (max-width: 1080px) { .rl-hero, .rl-replay-grid, .rl-main, .rl-bottom, .rl-stage-grid, .rl-detail-grid { grid-template-columns: 1fr; } }\n  @media (max-width: 720px) {\n    .rl-card-grid, .rl-side-grid, .rl-frame-metrics, .rl-control-grid { grid-template-columns: 1fr 1fr; }\n    .rl-slider-row { flex-wrap: wrap; }\n  }\n</style>\n\n<script>\n(function () {\n  var bootKey = '__rlReplayBoot';\n  function toInt(value, fallback) {\n    var parsed = parseInt(value, 10);\n    return isNaN(parsed) ? fallback : parsed;\n  }\n  function clearTimer(state) {\n    if (state.timerId) {\n      window.clearInterval(state.timerId);\n      state.timerId = null;\n    }\n  }\n  function install(rootId) {\n    var root = document.getElementById(rootId);\n    if (!root || !window.angular) {\n      return false;\n    }\n    var scope = angular.element(root).scope();\n    if (!scope || !scope.replayUi) {\n      return false;\n    }\n    if (scope.replayUi.__wired) {\n      return true;\n    }\n\n    scope.$applyAsync(function () {\n      var state = scope.replayUi;\n      if (state.__wired) {\n        return;\n      }\n      state.__wired = true;\n      state.playing = false;\n      state.timerId = null;\n      state.speedOptions = [\n        { label: '1x', delay: 650 },\n        { label: '2x', delay: 380 },\n        { label: '4x', delay: 220 },\n        { label: '8x', delay: 130 }\n      ];\n      state.speedLabel = state.speedLabel || '4x';\n      state.speedMs = state.speedMs || 220;\n      state.stepSize = state.stepSize || 1;\n\n      state.stop = function () {\n        clearTimer(state);\n        state.playing = false;\n      };\n      state.restart = function () {\n        state.frameIndex = 0;\n      };\n      state.prevFrame = function () {\n        state.frameIndex = Math.max(toInt(state.frameIndex, 0) - toInt(state.stepSize, 1), 0);\n      };\n      state.nextFrame = function (frameCount) {\n        var total = toInt(frameCount, 0);\n        if (!total) {\n          return;\n        }\n        var nextValue = toInt(state.frameIndex, 0) + toInt(state.stepSize, 1);\n        state.frameIndex = nextValue >= total ? total - 1 : nextValue;\n        if (state.frameIndex >= total - 1) {\n          state.stop();\n        }\n      };\n      state.play = function (frameCount) {\n        var total = toInt(frameCount, 0);\n        if (!total) {\n          return;\n        }\n        if (toInt(state.frameIndex, 0) >= total - 1) {\n          state.frameIndex = 0;\n        }\n        clearTimer(state);\n        state.playing = true;\n        state.timerId = window.setInterval(function () {\n          var liveRoot = document.getElementById(rootId);\n          if (!liveRoot || !window.angular) {\n            clearTimer(state);\n            state.playing = false;\n            return;\n          }\n          var liveScope = angular.element(liveRoot).scope();\n          if (!liveScope || !liveScope.replayUi) {\n            clearTimer(state);\n            state.playing = false;\n            return;\n          }\n          liveScope.$applyAsync(function () {\n            liveScope.replayUi.nextFrame(total);\n          });\n        }, toInt(state.speedMs, 220));\n      };\n      state.togglePlay = function (frameCount) {\n        if (state.playing) {\n          state.stop();\n        } else {\n          state.play(frameCount);\n        }\n      };\n      state.setSpeed = function (delay, label, frameCount) {\n        state.speedMs = toInt(delay, 220);\n        state.speedLabel = label;\n        if (state.playing) {\n          state.play(frameCount);\n        }\n      };\n    });\n\n    return true;\n  }\n\n  window[bootKey] = install;\n  (function retry() {\n    if (!install('rlReplayRoot')) {\n      window.setTimeout(retry, 150);\n    }\n  }());\n}());\n</script>\n\n<div class='rl-shell' id='rlReplayRoot'\n     ng-if='rlTradingShowcase.runs && rlTradingShowcase.runs.length'\n     ng-init='ui = { selectedRunId: (rlTradingShowcase.defaultRunId || rlTradingShowcase.runs[0].run_id) }; replayUi = { runId: ((rlTradingShowcase.checkpointReplay && rlTradingShowcase.checkpointReplay.defaultRunId) || null), checkpointId: null, frameIndex: 0, speedMs: 220, speedLabel: \"4x\", stepSize: 1, playing: false }'>\n  <div ng-repeat='current in [rlTradingShowcase.runMap[ui.selectedRunId] || rlTradingShowcase.runs[0]]'>\n    <section class='rl-hero'>\n      <div class='rl-panel'>\n        <div class='rl-kicker'>Zeppelin Dashboard PPO</div>\n        <h2>Theo dõi quá trình học của policy và replay checkpoint trên dữ liệu mới</h2>\n        <p>\n          Màn hình này ghép hai góc nhìn vào cùng một nơi: phần trên dùng checkpoint để replay day-by-day trên vài tháng dữ liệu gần đây,\n          phần dưới vẫn giữ toàn bộ chỉ số huấn luyện, benchmark và ảnh chụp thị trường để bạn thuyết trình mạch lạc hơn.\n        </p>\n        <div class='rl-chip-row'>\n          <span class='rl-chip'>Run đang xem: {{current.run_id}}</span>\n          <span class='rl-chip'>Giai đoạn đầu: {{current.early.label}}</span>\n          <span class='rl-chip'>Giai đoạn cuối: {{current.late.label}}</span>\n          <span class='rl-chip'>Live market: {{rlTradingShowcase.liveMarket.status_label}}</span>\n        </div>\n      </div>\n\n      <div class='rl-panel rl-side'>\n        <h3>Điều khiển dashboard</h3>\n        <label>Chọn run để xem báo cáo huấn luyện</label>\n        <select class='rl-select' ng-model='ui.selectedRunId' ng-options='run.run_id as run.label for run in rlTradingShowcase.runs'></select>\n        <div class='rl-side-grid'>\n          <div class='rl-mini'><span>Số run</span><strong>{{rlTradingShowcase.runs.length}}</strong></div>\n          <div class='rl-mini'><span>Mã live</span><strong>{{rlTradingShowcase.liveMarket.rows.length}}</strong></div>\n          <div class='rl-mini'><span>Tổng episode</span><strong>{{current.total_episodes}}</strong></div>\n          <div class='rl-mini'><span>Làm mới lúc</span><strong style='font-size:14px;'>{{rlTradingShowcase.liveMarket.refreshed_at}}</strong></div>\n        </div>\n      </div>\n    </section>\n\n    <section class='rl-panel rl-empty' ng-if='!rlTradingShowcase.checkpointReplay || rlTradingShowcase.checkpointReplay.status != \"ready\"'>\n      <h3>Replay checkpoint chưa sẵn sàng</h3>\n      <p>{{(rlTradingShowcase.checkpointReplay && rlTradingShowcase.checkpointReplay.message) || 'Paragraph setup chưa dựng được payload replay.'}}</p>\n      <div class='rl-alerts' ng-if='rlTradingShowcase.checkpointReplay && rlTradingShowcase.checkpointReplay.warnings && rlTradingShowcase.checkpointReplay.warnings.length'>\n        <span class='rl-alert' ng-repeat='warning in rlTradingShowcase.checkpointReplay.warnings'>{{warning}}</span>\n      </div>\n    </section>\n\n    <section class='rl-replay-grid'\n             ng-if='rlTradingShowcase.checkpointReplay && rlTradingShowcase.checkpointReplay.status == \"ready\" && rlTradingShowcase.checkpointReplay.runs.length'>\n      <div ng-repeat='replayRun in [rlTradingShowcase.checkpointReplay.runMap[replayUi.runId] || rlTradingShowcase.checkpointReplay.runs[0]]'\n           ng-init='replayUi.runId = replayUi.runId || replayRun.run_id; replayUi.checkpointId = replayUi.checkpointId || replayRun.defaultCheckpointId'>\n        <div ng-repeat='currentReplay in [replayRun.checkpointMap[replayUi.checkpointId] || replayRun.checkpoints[0]]'>\n          <div ng-repeat='frame in [currentReplay.frames[replayUi.frameIndex] || currentReplay.frames[0]]'>\n            <div class='rl-panel rl-terminal-panel'>\n              <div class='rl-replay-header'>\n                <div>\n                  <div class='rl-kicker'>Replay checkpoint</div>\n                  <h3>Soi policy theo từng ngày giao dịch mới</h3>\n                  <p>\n                    Chọn run, chọn checkpoint rồi kéo theo ngày để thấy policy lúc mới học phân bổ ra sao,\n                    và lúc cuối huấn luyện đã khác đi như thế nào.\n                  </p>\n                </div>\n                <div class='rl-badge-row'>\n                  <span class='rl-badge'>Nguồn dữ liệu: {{replayRun.data_source_label}}</span>\n                  <span class='rl-badge'>Cửa sổ demo: {{replayRun.display_start}} → {{replayRun.display_end}}</span>\n                </div>\n                <div class='rl-ticker-tape'>\n                  <span class='rl-ticker-chip' ng-repeat='ticker in replayRun.tickers'>{{ticker}}</span>\n                </div>\n              </div>\n\n              <div class='rl-control-grid'>\n                <div class='rl-control'>\n                  <label>Run cho replay</label>\n                  <select class='rl-select'\n                          ng-model='replayUi.runId'\n                          ng-options='run.run_id as run.label for run in rlTradingShowcase.checkpointReplay.runs'\n                          ng-change='replayUi.stop && replayUi.stop(); ui.selectedRunId = replayUi.runId; replayUi.checkpointId = rlTradingShowcase.checkpointReplay.runMap[replayUi.runId].defaultCheckpointId; replayUi.frameIndex = 0'>\n                  </select>\n                  <p class='rl-muted'>Chỉ precompute một số run gần nhất để setup không quá nặng.</p>\n                </div>\n\n                <div class='rl-control'>\n                  <label>Checkpoint đang xem</label>\n                  <select class='rl-select'\n                          ng-model='replayUi.checkpointId'\n                          ng-options='item.checkpoint_id as item.label for item in replayRun.checkpoints'\n                          ng-change='replayUi.stop && replayUi.stop(); replayUi.frameIndex = 0'>\n                  </select>\n                  <p class='rl-muted'>So sánh checkpoint đầu, checkpoint tốt nhất và checkpoint cuối theo cùng một màn hình.</p>\n                </div>\n              </div>\n\n              <div class='rl-frame-box'>\n                <h4>{{currentReplay.label}}</h4>\n                <p>{{frame.headline}}</p>\n                <div class='rl-meta-row'>\n                  <span class='rl-chip'>Khung {{replayUi.frameIndex + 1}} / {{currentReplay.frameCount}}</span>\n                  <span class='rl-chip'>Ngày quyết định: {{frame.decision_date}}</span>\n                  <span class='rl-chip'>Đóng phiên: {{frame.date}}</span>\n                  <span class='rl-chip'>Tốc độ: {{replayUi.speedLabel || '4x'}}</span>\n                  <span class='rl-chip' ng-if='currentReplay.step != null'>Bước train: {{currentReplay.step}}</span>\n                </div>\n                <div class='rl-speed-row'>\n                  <button class='rl-btn' ng-click='replayUi.togglePlay(currentReplay.frameCount)'>{{replayUi.playing ? 'Tạm dừng' : 'Phát tự động'}}</button>\n                  <button class='rl-btn' ng-click='replayUi.stop && replayUi.stop(); replayUi.restart()'>Về đầu</button>\n                  <button class='rl-btn' ng-click='replayUi.prevFrame()' ng-disabled='replayUi.frameIndex <= 0'>Lùi 1 ngày</button>\n                  <button class='rl-btn rl-btn-primary' ng-click='replayUi.nextFrame(currentReplay.frameCount)' ng-disabled='replayUi.frameIndex >= currentReplay.frameCount - 1'>Tiến 1 ngày</button>\n                  <button class='rl-btn'\n                          ng-repeat='speed in replayUi.speedOptions'\n                          ng-class='replayUi.speedLabel == speed.label ? \"rl-btn-primary\" : \"\"'\n                          ng-click='replayUi.setSpeed(speed.delay, speed.label, currentReplay.frameCount)'>{{speed.label}}</button>\n                </div>\n                <div class='rl-progress-line'>\n                  <div [style.width.%]='((replayUi.frameIndex + 1) / currentReplay.frameCount) * 100'></div>\n                </div>\n                <input class='rl-slider' type='range' min='0' max='{{currentReplay.frameCount - 1}}' ng-model='replayUi.frameIndex' ng-change='replayUi.stop && replayUi.stop()'>\n                <div class='rl-slider-row'>\n                  <span class='rl-muted'>Mặc định 4x để tua nhanh toàn bộ giai đoạn day-by-day trong vài giây thay vì kéo dài demo.</span>\n                </div>\n                <div class='rl-market-strip'>\n                  <div class='rl-market-tile'><span>Giá trị danh mục</span><strong>{{frame.portfolio_value | number:0}}</strong></div>\n                  <div class='rl-market-tile'><span>Lợi nhuận lũy kế</span><strong ng-class='frame.total_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{frame.total_return_pct | number:2}}%</strong></div>\n                  <div class='rl-market-tile'><span>Lợi nhuận ngày</span><strong ng-class='frame.day_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{frame.day_return_pct | number:2}}%</strong></div>\n                  <div class='rl-market-tile'><span>Tỷ trọng tiền mặt</span><strong>{{frame.cash_weight_pct | number:2}}%</strong></div>\n                </div>\n                <div class='rl-frame-metrics'>\n                  <div class='rl-metric'><span>So với danh mục đều</span><strong ng-class='frame.vs_equal_weight_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{frame.vs_equal_weight_pct | number:2}}%</strong></div>\n                  <div class='rl-metric'><span>So với mua và giữ</span><strong ng-class='frame.vs_buy_hold_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{frame.vs_buy_hold_pct | number:2}}%</strong></div>\n                  <div class='rl-metric'><span>Phí hôm nay</span><strong>{{frame.fees | number:0}}</strong></div>\n                  <div class='rl-metric'><span>Số lệnh</span><strong>{{frame.trade_count}}</strong></div>\n                  <div class='rl-metric'><span>Danh mục đều</span><strong>{{frame.equal_weight_value | number:0}}</strong></div>\n                  <div class='rl-metric'><span>Mua và giữ</span><strong>{{frame.buy_hold_value | number:0}}</strong></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div ng-repeat='replayRun in [rlTradingShowcase.checkpointReplay.runMap[replayUi.runId] || rlTradingShowcase.checkpointReplay.runs[0]]'\n           ng-init='replayUi.runId = replayUi.runId || replayRun.run_id; replayUi.checkpointId = replayUi.checkpointId || replayRun.defaultCheckpointId'>\n        <div ng-repeat='currentReplay in [replayRun.checkpointMap[replayUi.checkpointId] || replayRun.checkpoints[0]]'>\n          <div ng-repeat='frame in [currentReplay.frames[replayUi.frameIndex] || currentReplay.frames[0]]'>\n            <div class='rl-panel rl-replay-chart rl-terminal-panel'>\n              <h3>Đường vốn day-by-day trên dữ liệu mới</h3>\n              <p>\n                Đường xanh là checkpoint đang chọn, vàng là danh mục đều, xanh dương là mua và giữ.\n                Vạch dọc đánh dấu đúng ngày bạn đang tua.\n              </p>\n              <div class='rl-chart-meta'>\n                <span>Min {{currentReplay.chart.min_value | number:0}}</span>\n                <span>Max {{currentReplay.chart.max_value | number:0}}</span>\n                <span>Cuối kỳ {{currentReplay.summary.final_return_pct | number:2}}%</span>\n                <span>Dữ liệu {{replayRun.n_days}} ngày</span>\n              </div>\n              <div class='rl-legend'>\n                <span style='color:#2dd4bf;'>Checkpoint đang chọn</span>\n                <span style='color:#f4c76b;'>Danh mục đều</span>\n                <span style='color:#9fbce7;'>Mua và giữ</span>\n                <span style='color:#ff8a80;'>Vạch ngày hiện tại</span>\n              </div>\n              <div class='rl-chart-box'>\n                <svg viewBox='0 0 620 220' preserveAspectRatio='none'>\n                  <polyline [attr.points]='currentReplay.chart.buy_hold_points' fill='none' stroke='#6b8ab6' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'></polyline>\n                  <polyline [attr.points]='currentReplay.chart.equal_weight_points' fill='none' stroke='#d29922' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'></polyline>\n                  <polyline [attr.points]='currentReplay.chart.model_points' fill='none' stroke='#0f766e' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'></polyline>\n                  <line [attr.x1]='currentReplay.chart.marker_xs[replayUi.frameIndex]' [attr.x2]='currentReplay.chart.marker_xs[replayUi.frameIndex]' y1='14' y2='206' stroke='#d94841' stroke-dasharray='6 6'></line>\n                </svg>\n              </div>\n              <div class='rl-badge-row' style='margin-top:10px;'>\n                <span class='rl-badge'>Checkpoint hiện tại: {{currentReplay.label}}</span>\n                <span class='rl-badge'>Ngày hiển thị: {{frame.date}}</span>\n              </div>\n            </div>\n\n            <div class='rl-detail-grid' style='margin-top:16px;'>\n              <div class='rl-panel'>\n                <h3>Phân bổ mục tiêu của policy</h3>\n                <p>Top tỷ trọng mà policy muốn nắm giữ ở ngày hiện tại.</p>\n                <table class='rl-table'>\n                  <thead><tr><th>Tài sản</th><th>Tỷ trọng mục tiêu</th></tr></thead>\n                  <tbody>\n                    <tr ng-repeat='row in frame.top_allocations'>\n                      <td>{{row.label}}</td>\n                      <td>{{row.weight_pct | number:2}}%</td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n\n              <div class='rl-panel'>\n                <h3>Vị thế thực tế sau khớp lệnh</h3>\n                <p>Danh mục thực tế sau khi giao dịch ở giá mở và đánh dấu theo giá đóng cửa.</p>\n                <table class='rl-table'>\n                  <thead><tr><th>Tài sản</th><th>Giá trị</th><th>Tỷ trọng</th></tr></thead>\n                  <tbody>\n                    <tr ng-repeat='row in frame.top_positions'>\n                      <td>{{row.label}}</td>\n                      <td>{{row.position_value | number:0}}</td>\n                      <td>{{row.weight_pct | number:2}}%</td>\n                    </tr>\n                  </tbody>\n                </table>\n              </div>\n            </div>\n\n            <div class='rl-panel' style='margin-top:16px;'>\n              <h3>Giao dịch nổi bật trong ngày</h3>\n              <p>Bảng này giúp bạn chỉ ngay policy đang mua thêm gì, giảm tỷ trọng gì và giá khớp ở đâu.</p>\n              <table class='rl-table'>\n                <thead>\n                  <tr><th>Mã</th><th>Hướng</th><th>Số lượng</th><th>Giá mở</th><th>Giá đóng</th><th>Tỷ trọng mục tiêu</th></tr>\n                </thead>\n                <tbody>\n                  <tr ng-repeat='row in frame.trade_rows'>\n                    <td>{{row.symbol}}</td>\n                    <td>{{row.direction}}</td>\n                    <td>{{row.shares}}</td>\n                    <td>{{row.execution_price | number:0}}</td>\n                    <td>{{row.close_price | number:0}}</td>\n                    <td>{{row.target_weight_pct | number:2}}%</td>\n                  </tr>\n                </tbody>\n              </table>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <div class='rl-alerts' ng-if='rlTradingShowcase.checkpointReplay && rlTradingShowcase.checkpointReplay.warnings && rlTradingShowcase.checkpointReplay.warnings.length' style='margin-bottom:18px;'>\n      <span class='rl-alert' ng-repeat='warning in rlTradingShowcase.checkpointReplay.warnings | limitTo:4'>{{warning}}</span>\n    </div>\n\n    <section class='rl-card-grid'>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Tổng lợi nhuận cuối</div>\n        <div class='rl-card-value'>{{((current.summary.total_return != null ? current.summary.total_return : current.eval.final_test.total_return) * 100) | number:2}}%</div>\n        <div class='rl-card-sub'>Kết quả cuối cùng của run ở tập đánh giá.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Sharpe ratio</div>\n        <div class='rl-card-value'>{{(current.summary.sharpe_ratio != null ? current.summary.sharpe_ratio : current.eval.final_test.sharpe_ratio) | number:3}}</div>\n        <div class='rl-card-sub'>Mức lợi nhuận đã hiệu chỉnh theo rủi ro.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Mức cải thiện học</div>\n        <div class='rl-card-value' ng-class='current.delta_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{current.delta_return_pct | number:2}} điểm</div>\n        <div class='rl-card-sub'>Trung bình giai đoạn cuối trừ giai đoạn đầu.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Test so với danh mục đều</div>\n        <div class='rl-card-value' ng-class='current.benchmarks.highlights.test_equal_weight.delta_total_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{current.benchmarks.highlights.test_equal_weight.delta_total_return_pct | number:2}} điểm</div>\n        <div class='rl-card-sub'>Khoảng vượt benchmark đơn giản trên test.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Test so với mua và giữ</div>\n        <div class='rl-card-value' ng-class='current.benchmarks.highlights.test_buy_hold.delta_total_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{current.benchmarks.highlights.test_buy_hold.delta_total_return_pct | number:2}} điểm</div>\n        <div class='rl-card-sub'>Run có tốt hơn chiến lược giữ đều tỷ trọng hay không.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Tỷ lệ ngày thắng</div>\n        <div class='rl-card-value'>{{(current.summary.win_rate * 100) | number:2}}%</div>\n        <div class='rl-card-sub'>Tỷ lệ ngày mà lợi nhuận của run là dương.</div>\n      </div>\n    </section>\n\n    <section class='rl-main'>\n      <div class='rl-panel'>\n        <h3>Đường lợi nhuận theo episode</h3>\n        <p>Đường xám là từng episode, đường xanh là moving average để giải thích xu hướng học của agent.</p>\n        <div class='rl-chart-meta'>\n          <span>Min {{current.chart.min_value | number:2}}%</span>\n          <span>Max {{current.chart.max_value | number:2}}%</span>\n          <span>Episode cuối {{current.chart.latest_value | number:2}}%</span>\n          <span>Số update {{current.total_updates}}</span>\n        </div>\n        <div class='rl-chart-box'>\n          <svg viewBox='0 0 620 220' preserveAspectRatio='none'>\n            <line ng-if='current.chart.zero_y != null' x1='14' x2='606' [attr.y1]='current.chart.zero_y' [attr.y2]='current.chart.zero_y' stroke='#cbd6e4' stroke-dasharray='6 6'></line>\n            <polyline [attr.points]='current.chart.raw_points' fill='none' stroke='#90a4bb' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'></polyline>\n            <polyline [attr.points]='current.chart.ma_points' fill='none' stroke='#0f766e' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'></polyline>\n          </svg>\n        </div>\n        <div class='rl-note'>Nếu moving average nửa sau cao hơn nửa đầu, bạn có cơ sở để giải thích policy đang học tốt hơn qua thời gian.</div>\n      </div>\n\n      <div>\n        <div class='rl-panel' style='margin-bottom:16px;'>\n          <h3>Snapshot thị trường hiện tại</h3>\n          <p>Phần này nối artifact huấn luyện với giá thị trường hiện tại. Chạy lại paragraph setup nếu muốn refresh live quote.</p>\n          <table class='rl-table'>\n            <thead>\n              <tr><th>Mã</th><th>Giá live</th><th>1 ngày</th><th>So với local</th><th>Trạng thái</th></tr>\n            </thead>\n            <tbody>\n              <tr ng-repeat='row in rlTradingShowcase.liveMarket.rows'>\n                <td><strong>{{row.symbol}}</strong><br><span class='rl-muted'>{{row.last_date}}</span></td>\n                <td><strong ng-if='row.live_price != null'>{{row.live_price | number:0}}</strong><strong ng-if='row.live_price == null'>N/A</strong><br><span class='rl-muted'>local {{row.last_close | number:0}}</span></td>\n                <td ng-class='row.change_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.change_pct | number:2}}%</td>\n                <td ng-class='row.gap_vs_last_close_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.gap_vs_last_close_pct | number:2}}%</td>\n                <td><span class='rl-status' ng-class='row.status == \"LIVE\" ? \"rl-live\" : \"rl-fallback\"'>{{row.status}}</span></td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n\n        <div class='rl-panel'>\n          <h3>Ống kính benchmark</h3>\n          <p>Cho thấy model đang vượt hay thua các baseline trên validation và test.</p>\n          <table class='rl-table'>\n            <thead>\n              <tr><th>Stage</th><th>Baseline</th><th>Delta return</th><th>Delta sharpe</th></tr>\n            </thead>\n            <tbody>\n              <tr ng-repeat='row in current.benchmarks.rows'>\n                <td>{{row.stage}}</td>\n                <td>{{row.baseline}}</td>\n                <td ng-class='row.delta_total_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.delta_total_return_pct | number:2}} điểm</td>\n                <td ng-class='row.delta_sharpe_ratio >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.delta_sharpe_ratio | number:3}}</td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </section>\n\n    <section class='rl-bottom'>\n      <div class='rl-panel'>\n        <h3>Thông tin run</h3>\n        <table class='rl-table'>\n          <tbody>\n            <tr><th>Total timesteps</th><td>{{current.config.total_timesteps}}</td></tr>\n            <tr><th>n_steps</th><td>{{current.config.n_steps}}</td></tr>\n            <tr><th>batch_size</th><td>{{current.config.batch_size}}</td></tr>\n            <tr><th>hidden_size</th><td>{{current.config.hidden_size}}</td></tr>\n            <tr><th>max_steps_train</th><td>{{current.config.max_steps_train}}</td></tr>\n            <tr><th>max_steps_eval</th><td>{{current.config.max_steps_eval}}</td></tr>\n            <tr><th>Bắt đầu</th><td>{{current.started_at}}</td></tr>\n            <tr><th>Kết thúc</th><td>{{current.ended_at}}</td></tr>\n          </tbody>\n        </table>\n\n        <h3 style='margin-top:16px;'>Snapshot đánh giá</h3>\n        <table class='rl-table'>\n          <thead><tr><th>Stage</th><th>Episode</th><th>Sharpe</th><th>Return</th></tr></thead>\n          <tbody>\n            <tr><td>Val đầu</td><td>{{current.eval.first_val.episode}}</td><td>{{current.eval.first_val.sharpe_ratio | number:3}}</td><td>{{(current.eval.first_val.total_return * 100) | number:2}}%</td></tr>\n            <tr><td>Val cuối</td><td>{{current.eval.last_val.episode}}</td><td>{{current.eval.last_val.sharpe_ratio | number:3}}</td><td>{{(current.eval.last_val.total_return * 100) | number:2}}%</td></tr>\n            <tr><td>Test cuối</td><td>{{current.eval.final_test.episode}}</td><td>{{current.eval.final_test.sharpe_ratio | number:3}}</td><td>{{(current.eval.final_test.total_return * 100) | number:2}}%</td></tr>\n          </tbody>\n        </table>\n      </div>\n\n      <div class='rl-panel'>\n        <h3>Data split và cực trị</h3>\n        <table class='rl-table'>\n          <thead><tr><th>Split</th><th>Bắt đầu</th><th>Kết thúc</th><th>Số ngày</th></tr></thead>\n          <tbody>\n            <tr><td>train</td><td>{{current.split.train.start}}</td><td>{{current.split.train.end}}</td><td>{{current.split.train.days}}</td></tr>\n            <tr><td>val</td><td>{{current.split.val.start}}</td><td>{{current.split.val.end}}</td><td>{{current.split.val.days}}</td></tr>\n            <tr><td>test</td><td>{{current.split.test.start}}</td><td>{{current.split.test.end}}</td><td>{{current.split.test.days}}</td></tr>\n          </tbody>\n        </table>\n        <h3 style='margin-top:16px;'>Episode tốt nhất và tệ nhất</h3>\n        <table class='rl-table'>\n          <tbody>\n            <tr><th>Best episode</th><td>{{current.best_episode.episode}}</td><td>{{current.best_episode.total_return_pct | number:2}}%</td></tr>\n            <tr><th>Worst episode</th><td>{{current.worst_episode.episode}}</td><td>{{current.worst_episode.total_return_pct | number:2}}%</td></tr>\n            <tr><th>Best portfolio</th><td colspan='2'>{{current.best_episode.portfolio_value | number:0}}</td></tr>\n            <tr><th>Worst portfolio</th><td colspan='2'>{{current.worst_episode.portfolio_value | number:0}}</td></tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n\n    <section class='rl-stage-grid'>\n      <div class='rl-panel'>\n        <h3>{{current.early.label}}</h3>\n        <p>Giai đoạn này hữu ích để giải thích policy còn dò đường, tỷ suất và số giao dịch thường chưa ổn định.</p>\n        <table class='rl-table'>\n          <thead><tr><th>Episode</th><th>Return</th><th>Portfolio</th><th>Trades</th></tr></thead>\n          <tbody>\n            <tr ng-repeat='row in current.early.rows'>\n              <td>{{row.episode}}</td><td>{{row.total_return_pct | number:2}}%</td><td>{{row.portfolio_value | number:0}}</td><td>{{row.n_trades}}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n      <div class='rl-panel'>\n        <h3>{{current.late.label}}</h3>\n        <p>Đặt cạnh giai đoạn đầu để thấy sau khi train xong policy đã bớt nhiễu và phân bổ vốn có chủ đích hơn.</p>\n        <table class='rl-table'>\n          <thead><tr><th>Episode</th><th>Return</th><th>Portfolio</th><th>Trades</th></tr></thead>\n          <tbody>\n            <tr ng-repeat='row in current.late.rows'>\n              <td>{{row.episode}}</td><td>{{row.total_return_pct | number:2}}%</td><td>{{row.portfolio_value | number:0}}</td><td>{{row.n_trades}}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n  </div>\n</div>\n","user":"sin235","dateUpdated":"2026-03-22T09:29:41+0000","progress":0,"config":{"lineNumbers":true,"editorSetting":{"language":"plain_text","editOnDblClick":false,"completionKey":"TAB","completionSupport":true},"editorMode":"ace/mode/plain_text","colWidth":12,"editorHide":false,"fontSize":9,"results":{},"enabled":true},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"ANGULAR","data":"\n<style>\n  .rl-shell {\n    --ink: #132238;\n    --muted: #617186;\n    --line: #d9e1ea;\n    --sea: #0f766e;\n    --slate: #0f172a;\n    font-family: 'Aptos', 'Trebuchet MS', 'Segoe UI', sans-serif;\n    color: var(--ink);\n    background:\n      radial-gradient(circle at top right, rgba(255, 215, 152, 0.35), transparent 30%),\n      radial-gradient(circle at left bottom, rgba(160, 225, 199, 0.28), transparent 25%),\n      linear-gradient(180deg, #fffdf8 0%, #f6fafc 100%);\n    border: 1px solid #ebe5d8;\n    border-radius: 26px;\n    padding: 24px;\n  }\n  .rl-hero, .rl-main, .rl-bottom, .rl-stage-grid { display: grid; gap: 16px; }\n  .rl-hero { grid-template-columns: 1.45fr 0.95fr; margin-bottom: 18px; }\n  .rl-main { grid-template-columns: 1.4fr 1fr; margin-bottom: 18px; }\n  .rl-bottom { grid-template-columns: 1fr 1fr; margin-bottom: 18px; }\n  .rl-stage-grid { grid-template-columns: 1fr 1fr; }\n  .rl-panel {\n    background: rgba(255, 255, 255, 0.86);\n    border: 1px solid rgba(217, 225, 234, 0.95);\n    border-radius: 20px;\n    padding: 18px;\n    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);\n  }\n  .rl-hero-main h2 { margin: 0 0 10px 0; font-size: 34px; line-height: 1.08; }\n  .rl-hero-main p, .rl-panel p { margin: 0 0 12px 0; color: var(--muted); line-height: 1.55; }\n  .rl-kicker {\n    display: inline-block;\n    padding: 6px 10px;\n    border-radius: 999px;\n    background: #e4f6ec;\n    color: #15624f;\n    font-size: 12px;\n    font-weight: 800;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    margin-bottom: 10px;\n  }\n  .rl-chip-row { display: flex; flex-wrap: wrap; gap: 8px; }\n  .rl-chip {\n    border-radius: 999px;\n    padding: 7px 11px;\n    background: #edf5ff;\n    color: #2d4d74;\n    font-size: 12px;\n    font-weight: 700;\n  }\n  .rl-side {\n    background: var(--slate);\n    color: #f8fafc;\n  }\n  .rl-side label {\n    display: block;\n    margin-bottom: 8px;\n    font-size: 12px;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    opacity: 0.72;\n  }\n  .rl-side select {\n    width: 100%;\n    padding: 11px 12px;\n    border-radius: 14px;\n    border: none;\n    margin-bottom: 14px;\n    color: var(--ink);\n  }\n  .rl-side-grid, .rl-kpis { display: grid; gap: 12px; }\n  .rl-side-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }\n  .rl-kpis { grid-template-columns: repeat(6, minmax(0, 1fr)); margin-bottom: 18px; }\n  .rl-mini {\n    background: rgba(255, 255, 255, 0.08);\n    border-radius: 16px;\n    padding: 12px;\n  }\n  .rl-mini span { display: block; font-size: 12px; opacity: 0.72; margin-bottom: 4px; }\n  .rl-mini strong { font-size: 22px; font-weight: 800; }\n  .rl-card {\n    background: rgba(255,255,255,0.86);\n    border: 1px solid rgba(217, 225, 234, 0.95);\n    border-radius: 18px;\n    padding: 16px;\n    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);\n  }\n  .rl-card-label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }\n  .rl-card-value { font-size: 26px; font-weight: 800; line-height: 1.08; }\n  .rl-card-sub, .rl-note { margin-top: 8px; color: var(--muted); font-size: 12px; line-height: 1.45; }\n  .rl-positive { color: #117a46; }\n  .rl-negative { color: #b42318; }\n  .rl-table { width: 100%; border-collapse: collapse; }\n  .rl-table th, .rl-table td {\n    padding: 10px 8px;\n    border-bottom: 1px solid var(--line);\n    text-align: left;\n    font-size: 13px;\n    vertical-align: top;\n  }\n  .rl-table th { color: var(--muted); font-weight: 700; }\n  .rl-status {\n    display: inline-flex;\n    border-radius: 999px;\n    padding: 5px 9px;\n    font-size: 11px;\n    font-weight: 800;\n    background: #eef5ff;\n    color: #285e91;\n  }\n  .rl-live { background: #e9fbee; color: #16643b; }\n  .rl-fallback { background: #fff3e6; color: #9a5d08; }\n  .rl-chart-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }\n  .rl-chart-meta span {\n    border-radius: 999px;\n    padding: 6px 10px;\n    background: #ecfdf7;\n    color: #16645a;\n    font-size: 12px;\n    font-weight: 700;\n  }\n  .rl-chart-box {\n    background: linear-gradient(180deg, #fbfdfd 0%, #f0f7ff 100%);\n    border-radius: 18px;\n    padding: 10px;\n  }\n  .rl-chart-box svg { width: 100%; height: 280px; }\n  .rl-alerts { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }\n  .rl-alert {\n    border-radius: 999px;\n    padding: 7px 11px;\n    background: #fff2d8;\n    color: #8d5a05;\n    font-size: 12px;\n    font-weight: 700;\n  }\n  @media (max-width: 1260px) { .rl-kpis { grid-template-columns: repeat(3, minmax(0, 1fr)); } }\n  @media (max-width: 1024px) { .rl-hero, .rl-main, .rl-bottom, .rl-stage-grid { grid-template-columns: 1fr; } }\n  @media (max-width: 720px) { .rl-kpis, .rl-side-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }\n</style>\n\n<div class='rl-shell' ng-if='rlTradingShowcase.runs' ng-init='selectedRunId = rlTradingShowcase.defaultRunId'>\n  <div ng-repeat='current in [rlTradingShowcase.runMap[selectedRunId]]'>\n    <section class='rl-hero'>\n      <div class='rl-panel rl-hero-main'>\n        <div class='rl-kicker'>Self-contained Zeppelin Notebook</div>\n        <h2>PPO Trading progress, benchmark va live market trong cung mot dashboard</h2>\n        <p>\n          Notebook nay khong can import helper `.py` tu ben ngoai. Paragraph setup se doc artifact\n          huan luyen, tao temp view Spark va bind du lieu cho Angular. Live market duoc lay qua mang,\n          neu that bai thi dashboard tu dong fallback ve processed close.\n        </p>\n        <div class='rl-chip-row'>\n          <span class='rl-chip'>Run: {{current.run_id}}</span>\n          <span class='rl-chip'>Early: {{current.early.label}}</span>\n          <span class='rl-chip'>Late: {{current.late.label}}</span>\n          <span class='rl-chip'>Network: {{rlTradingShowcase.liveMarket.status_label}}</span>\n        </div>\n      </div>\n      <div class='rl-panel rl-side'>\n        <label>Chon run de demo</label>\n        <select ng-model='selectedRunId' ng-options='run.run_id as run.label for run in rlTradingShowcase.runs'></select>\n        <div class='rl-side-grid'>\n          <div class='rl-mini'><span>So run</span><strong>{{rlTradingShowcase.runs.length}}</strong></div>\n          <div class='rl-mini'><span>Tracked tickers</span><strong>{{rlTradingShowcase.liveMarket.rows.length}}</strong></div>\n          <div class='rl-mini'><span>Total episodes</span><strong>{{current.total_episodes}}</strong></div>\n          <div class='rl-mini'><span>Refresh at</span><strong style='font-size:14px;'>{{rlTradingShowcase.liveMarket.refreshed_at}}</strong></div>\n        </div>\n      </div>\n    </section>\n\n    <section class='rl-kpis'>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Final Total Return</div>\n        <div class='rl-card-value'>{{((current.summary.total_return != null ? current.summary.total_return : current.eval.final_test.total_return) * 100) | number:2}}%</div>\n        <div class='rl-card-sub'>Tong return cuoi run.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Sharpe Ratio</div>\n        <div class='rl-card-value'>{{(current.summary.sharpe_ratio != null ? current.summary.sharpe_ratio : current.eval.final_test.sharpe_ratio) | number:3}}</div>\n        <div class='rl-card-sub'>Chi so risk-adjusted.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Learning Delta</div>\n        <div class='rl-card-value' ng-class='current.delta_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{current.delta_return_pct | number:2}} pts</div>\n        <div class='rl-card-sub'>Late avg tru early avg.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Test vs Equal Weight</div>\n        <div class='rl-card-value' ng-class='current.benchmarks.highlights.test_equal_weight.delta_total_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{current.benchmarks.highlights.test_equal_weight.delta_total_return_pct | number:2}} pts</div>\n        <div class='rl-card-sub'>Delta tong return tren test.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Test vs Buy & Hold</div>\n        <div class='rl-card-value' ng-class='current.benchmarks.highlights.test_buy_hold.delta_total_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{current.benchmarks.highlights.test_buy_hold.delta_total_return_pct | number:2}} pts</div>\n        <div class='rl-card-sub'>Do vuot baseline buy & hold.</div>\n      </div>\n      <div class='rl-card'>\n        <div class='rl-card-label'>Win Rate</div>\n        <div class='rl-card-value'>{{(current.summary.win_rate * 100) | number:2}}%</div>\n        <div class='rl-card-sub'>Ty le ngay co return duong.</div>\n      </div>\n    </section>\n\n    <section class='rl-main'>\n      <div class='rl-panel'>\n        <h3>Episode Return Curve</h3>\n        <p>Duong xam la tung episode, duong xanh la moving average de thay agent co hoc len hay khong.</p>\n        <div class='rl-chart-meta'>\n          <span>Min {{current.chart.min_value | number:2}}%</span>\n          <span>Max {{current.chart.max_value | number:2}}%</span>\n          <span>Latest {{current.chart.latest_value | number:2}}%</span>\n          <span>Updates {{current.total_updates}}</span>\n        </div>\n        <div class='rl-chart-box'>\n          <svg viewBox='0 0 620 220' preserveAspectRatio='none'>\n            <line ng-if='current.chart.zero_y != null' x1='14' x2='606' [attr.y1]='current.chart.zero_y' [attr.y2]='current.chart.zero_y' stroke='#cbd6e4' stroke-dasharray='6 6'></line>\n            <polyline [attr.points]='current.chart.raw_points' fill='none' stroke='#90a4bb' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'></polyline>\n            <polyline [attr.points]='current.chart.ma_points' fill='none' stroke='#0f766e' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'></polyline>\n          </svg>\n        </div>\n        <div class='rl-note'>Neu moving average o nua sau cao hon nua dau, thay co the giai thich rang policy dang hoc tot hon.</div>\n      </div>\n\n      <div>\n        <div class='rl-panel' style='margin-bottom:16px;'>\n          <h3>Live Market Snapshot</h3>\n          <p>Bang nay noi artifact huan luyen voi gia thi truong hien tai. Rerun paragraph setup de refresh live quote.</p>\n          <table class='rl-table'>\n            <thead>\n              <tr><th>Symbol</th><th>Live</th><th>1d</th><th>Vs local</th><th>Status</th></tr>\n            </thead>\n            <tbody>\n              <tr ng-repeat='row in rlTradingShowcase.liveMarket.rows'>\n                <td><strong>{{row.symbol}}</strong><br><span style='color:#617186;'>{{row.last_date}}</span></td>\n                <td><strong ng-if='row.live_price != null'>{{row.live_price | number:0}}</strong><strong ng-if='row.live_price == null'>N/A</strong><br><span style='color:#617186;'>local {{row.last_close | number:0}}</span></td>\n                <td ng-class='row.change_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.change_pct | number:2}}%</td>\n                <td ng-class='row.gap_vs_last_close_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.gap_vs_last_close_pct | number:2}}%</td>\n                <td><span class='rl-status' ng-class='row.status == \"LIVE\" ? \"rl-live\" : \"rl-fallback\"'>{{row.status}}</span></td>\n              </tr>\n            </tbody>\n          </table>\n          <div class='rl-alerts' ng-if='rlTradingShowcase.liveMarket.alerts.length'>\n            <span class='rl-alert' ng-repeat='alert in rlTradingShowcase.liveMarket.alerts'>{{alert}}</span>\n          </div>\n        </div>\n\n        <div class='rl-panel'>\n          <h3>Benchmark Lens</h3>\n          <p>Cho thay model dang vuot hay thua baseline tren validation va test.</p>\n          <table class='rl-table'>\n            <thead>\n              <tr><th>Stage</th><th>Baseline</th><th>Delta return</th><th>Delta sharpe</th></tr>\n            </thead>\n            <tbody>\n              <tr ng-repeat='row in current.benchmarks.rows'>\n                <td>{{row.stage}}</td>\n                <td>{{row.baseline}}</td>\n                <td ng-class='row.delta_total_return_pct >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.delta_total_return_pct | number:2}} pts</td>\n                <td ng-class='row.delta_sharpe_ratio >= 0 ? \"rl-positive\" : \"rl-negative\"'>{{row.delta_sharpe_ratio | number:3}}</td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </section>\n\n    <section class='rl-bottom'>\n      <div class='rl-panel'>\n        <h3>Run Snapshot</h3>\n        <table class='rl-table'>\n          <tbody>\n            <tr><th>Total timesteps</th><td>{{current.config.total_timesteps}}</td></tr>\n            <tr><th>n_steps</th><td>{{current.config.n_steps}}</td></tr>\n            <tr><th>batch_size</th><td>{{current.config.batch_size}}</td></tr>\n            <tr><th>hidden_size</th><td>{{current.config.hidden_size}}</td></tr>\n            <tr><th>max_steps_train</th><td>{{current.config.max_steps_train}}</td></tr>\n            <tr><th>max_steps_eval</th><td>{{current.config.max_steps_eval}}</td></tr>\n            <tr><th>Started</th><td>{{current.started_at}}</td></tr>\n            <tr><th>Ended</th><td>{{current.ended_at}}</td></tr>\n          </tbody>\n        </table>\n\n        <h3 style='margin-top:16px;'>Eval Snapshot</h3>\n        <table class='rl-table'>\n          <thead><tr><th>Stage</th><th>Episode</th><th>Sharpe</th><th>Return</th></tr></thead>\n          <tbody>\n            <tr><td>First val</td><td>{{current.eval.first_val.episode}}</td><td>{{current.eval.first_val.sharpe_ratio | number:3}}</td><td>{{(current.eval.first_val.total_return * 100) | number:2}}%</td></tr>\n            <tr><td>Last val</td><td>{{current.eval.last_val.episode}}</td><td>{{current.eval.last_val.sharpe_ratio | number:3}}</td><td>{{(current.eval.last_val.total_return * 100) | number:2}}%</td></tr>\n            <tr><td>Final test</td><td>{{current.eval.final_test.episode}}</td><td>{{current.eval.final_test.sharpe_ratio | number:3}}</td><td>{{(current.eval.final_test.total_return * 100) | number:2}}%</td></tr>\n          </tbody>\n        </table>\n      </div>\n\n      <div class='rl-panel'>\n        <h3>Data Split And Extremes</h3>\n        <table class='rl-table'>\n          <thead><tr><th>Split</th><th>Start</th><th>End</th><th>Days</th></tr></thead>\n          <tbody>\n            <tr><td>train</td><td>{{current.split.train.start}}</td><td>{{current.split.train.end}}</td><td>{{current.split.train.days}}</td></tr>\n            <tr><td>val</td><td>{{current.split.val.start}}</td><td>{{current.split.val.end}}</td><td>{{current.split.val.days}}</td></tr>\n            <tr><td>test</td><td>{{current.split.test.start}}</td><td>{{current.split.test.end}}</td><td>{{current.split.test.days}}</td></tr>\n          </tbody>\n        </table>\n        <h3 style='margin-top:16px;'>Episode Extremes</h3>\n        <table class='rl-table'>\n          <tbody>\n            <tr><th>Best episode</th><td>{{current.best_episode.episode}}</td><td>{{current.best_episode.total_return_pct | number:2}}%</td></tr>\n            <tr><th>Worst episode</th><td>{{current.worst_episode.episode}}</td><td>{{current.worst_episode.total_return_pct | number:2}}%</td></tr>\n            <tr><th>Best portfolio</th><td colspan='2'>{{current.best_episode.portfolio_value | number:0}}</td></tr>\n            <tr><th>Worst portfolio</th><td colspan='2'>{{current.worst_episode.portfolio_value | number:0}}</td></tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n\n    <section class='rl-stage-grid'>\n      <div class='rl-panel'>\n        <h3>{{current.early.label}}</h3>\n        <p>Nhieu khi chi can cho thay giai doan dau con loi, de giai thich agent dang hoc tu tu.</p>\n        <table class='rl-table'>\n          <thead><tr><th>Episode</th><th>Return</th><th>Portfolio</th><th>Trades</th></tr></thead>\n          <tbody>\n            <tr ng-repeat='row in current.early.rows'>\n              <td>{{row.episode}}</td><td>{{row.total_return_pct | number:2}}%</td><td>{{row.portfolio_value | number:0}}</td><td>{{row.n_trades}}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n      <div class='rl-panel'>\n        <h3>{{current.late.label}}</h3>\n        <p>Bang nay doi chieu voi giai doan dau de thay muc do cai thien sau khi train xong.</p>\n        <table class='rl-table'>\n          <thead><tr><th>Episode</th><th>Return</th><th>Portfolio</th><th>Trades</th></tr></thead>\n          <tbody>\n            <tr ng-repeat='row in current.late.rows'>\n              <td>{{row.episode}}</td><td>{{row.total_return_pct | number:2}}%</td><td>{{row.portfolio_value | number:0}}</td><td>{{row.n_trades}}</td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n  </div>\n</div>\n"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774171552371_1155877238","id":"paragraph_73f636c2a1a6469bbf95be88ce555c88","dateCreated":"2026-03-22T09:25:52+0000","dateStarted":"2026-03-22T09:29:41+0000","dateFinished":"2026-03-22T09:29:41+0000","status":302}],"info":{"isRunning":false},"noteForms":{},"noteParams":{},"angularObjects":{}}